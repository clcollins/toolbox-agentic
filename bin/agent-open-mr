#!/usr/bin/env bash
# agent-open-mr — push the current branch and open a GitLab MR with attribution.
#
# Usage: agent-open-mr "MR title" ["MR body"]
#   Run from inside a cloned repo directory.
#   Pushes the current branch, opens an MR against the default branch.
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "usage: agent-open-mr \"MR title\" [\"MR body\"]" >&2
  exit 1
fi

TITLE="$1"
BODY="${2:-}"

BRANCH="$(git rev-parse --abbrev-ref HEAD)"
DEFAULT_BRANCH="$(glab repo view --output json | jq -r '.default_branch')"

if [[ "$BRANCH" == "$DEFAULT_BRANCH" ]]; then
  echo "[agent-open-mr] ERROR: on default branch ($DEFAULT_BRANCH); create a feature branch first" >&2
  exit 1
fi

ATTRIBUTION=$'\n---\n\U0001f916 Generated with [Claude Code](https://claude.com/claude-code)'

if [[ -n "$BODY" ]]; then
  FULL_BODY="${BODY}${ATTRIBUTION}"
else
  FULL_BODY="${ATTRIBUTION}"
fi

git push --set-upstream origin "$BRANCH"

glab mr create \
  --title "$TITLE" \
  --description "$FULL_BODY" \
  --target-branch "$DEFAULT_BRANCH" \
  --source-branch "$BRANCH" \
  --remove-source-branch

echo "[agent-open-mr] MR opened for $BRANCH -> $DEFAULT_BRANCH"
