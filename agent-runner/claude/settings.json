{
  "permissions": {
    "allow": [
      "Bash(agent-clone *)",
      "Bash(agent-open-pr *)",
      "Bash(agent-open-mr *)",
      "Bash(agent-ci-watch *)",
      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(glab *)",
      "Bash(make *)",
      "Bash(jq *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(tar *)",
      "Bash(gzip *)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.config/glab-cli/**)",
      "Read(**/.env)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.config/gh/**)",
      "Edit(~/.config/glab-cli/**)",
      "Edit(**/.env)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "test -n \"$CLAUDE_TOOL_FILE_PATH\" && [[ \"$CLAUDE_TOOL_FILE_PATH\" == *.go ]] && gofmt -w \"$CLAUDE_TOOL_FILE_PATH\" || true"
          }
        ]
      }
    ]
  },
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_UPDATES": "1",
    "DISABLE_TELEMETRY": "1"
  }
}
