#!/usr/bin/env bash
# agent-ci-watch — block until CI finishes for the current branch.
#
# Usage: agent-ci-watch [github|gitlab]
#   Defaults to github. Polls every 30s until all checks/pipelines complete.
#   Exits 0 on success, 1 on failure, 2 on timeout.
set -euo pipefail

PROVIDER="${1:-github}"
TIMEOUT="${AGENT_CI_TIMEOUT:-1800}"
POLL_INTERVAL=30
ELAPSED=0

case "$PROVIDER" in
  github)
    BRANCH="$(git rev-parse --abbrev-ref HEAD)"
    SHA="$(git rev-parse HEAD)"
    echo "[agent-ci-watch] watching GitHub checks for $BRANCH ($SHA)..."
    while [[ $ELAPSED -lt $TIMEOUT ]]; do
      STATUS="$(gh run list --branch "$BRANCH" --limit 1 --json status,conclusion --jq '.[0] // empty')"
      if [[ -z "$STATUS" ]]; then
        echo "[agent-ci-watch] no runs found yet, waiting..."
        sleep "$POLL_INTERVAL"
        ELAPSED=$((ELAPSED + POLL_INTERVAL))
        continue
      fi
      RUN_STATUS="$(echo "$STATUS" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("status",""))')"
      CONCLUSION="$(echo "$STATUS" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("conclusion",""))')"
      if [[ "$RUN_STATUS" == "completed" ]]; then
        echo "[agent-ci-watch] CI completed: $CONCLUSION"
        if [[ "$CONCLUSION" == "success" ]]; then
          exit 0
        else
          exit 1
        fi
      fi
      echo "[agent-ci-watch] status=$RUN_STATUS, waiting ${POLL_INTERVAL}s (${ELAPSED}s/${TIMEOUT}s)..."
      sleep "$POLL_INTERVAL"
      ELAPSED=$((ELAPSED + POLL_INTERVAL))
    done
    echo "[agent-ci-watch] timeout after ${TIMEOUT}s" >&2
    exit 2
    ;;
  gitlab)
    BRANCH="$(git rev-parse --abbrev-ref HEAD)"
    echo "[agent-ci-watch] watching GitLab pipeline for $BRANCH..."
    while [[ $ELAPSED -lt $TIMEOUT ]]; do
      PIPELINE="$(glab ci status --branch "$BRANCH" --output json 2>/dev/null || echo '{}')"
      STATUS="$(echo "$PIPELINE" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("status","unknown"))' 2>/dev/null || echo "unknown")"
      case "$STATUS" in
        success)
          echo "[agent-ci-watch] pipeline succeeded"
          exit 0
          ;;
        failed|canceled)
          echo "[agent-ci-watch] pipeline $STATUS"
          exit 1
          ;;
        unknown|"")
          echo "[agent-ci-watch] no pipeline found yet, waiting..."
          ;;
        *)
          echo "[agent-ci-watch] status=$STATUS, waiting ${POLL_INTERVAL}s (${ELAPSED}s/${TIMEOUT}s)..."
          ;;
      esac
      sleep "$POLL_INTERVAL"
      ELAPSED=$((ELAPSED + POLL_INTERVAL))
    done
    echo "[agent-ci-watch] timeout after ${TIMEOUT}s" >&2
    exit 2
    ;;
  *)
    echo "usage: agent-ci-watch [github|gitlab]" >&2
    exit 1
    ;;
esac
