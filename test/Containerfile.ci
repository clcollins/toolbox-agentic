FROM registry.fedoraproject.org/fedora-minimal:42

RUN microdnf install -y \
      python3 \
      python3-pip \
      bash \
      ShellCheck \
      jq \
      make \
      findutils \
      git \
      bats \
    && microdnf clean all

# Python-based linting and test tools (pinned for reproducibility)
RUN pip install --break-system-packages \
      yamllint==1.37.0 \
      ruff==0.11.12 \
      pytest==8.3.5 \
      pytest-timeout==2.3.1 \
      pyyaml==6.0.2

# hadolint (static binary, pinned)
ARG HADOLINT_VERSION=2.12.0
ARG TARGETARCH=amd64
RUN curl -fsSLo /usr/local/bin/hadolint \
      "https://github.com/hadolint/hadolint/releases/download/v${HADOLINT_VERSION}/hadolint-Linux-x86_64" \
    && chmod 0755 /usr/local/bin/hadolint

# Git identity for bats tests that create test repos with commits
RUN git config --global user.name "ci-test" \
    && git config --global user.email "ci-test@localhost" \
    && git config --global init.defaultBranch main

WORKDIR /src
